---
import Navbar from "../components/Navbar/Navbar.astro";
import Footer from "../components/Footer/Footer.astro";
import WhatsAppFloat from "../components/WhatsAppFloat/WhatsAppFloat.astro";
import "../styles/global.css";
---

<html lang="es-MX">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="dark light" />
    <title>Usuario - Solución Factura</title>
    <meta
      name="description"
      content="Formulario de usuario para Solución Factura."
    />
    <script is:inline>
      (function () {
        const savedTheme = localStorage.getItem("theme");
        const prefersDark =
          window.matchMedia &&
          window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = savedTheme || (prefersDark ? "dark" : "light");
        const html = document.documentElement;
        if (theme === "dark") {
          html.setAttribute("data-theme", "dark");
          html.classList.add("dark");
        } else {
          html.setAttribute("data-theme", "light");
          html.classList.remove("dark");
        }
      })();
    </script>
    <script src="../scripts/theme.js"></script>
  </head>
  <body class="min-h-screen">
    <Navbar />
    <main
      class="py-16 md:py-20 lg:py-24 bg-bg-primary-light dark:bg-bg-primary"
    >
      <div class="w-full max-w-[1200px] mx-auto px-4 sm:px-6 md:px-8 lg:px-10">
        <div class="text-center mb-12 md:mb-16">
          <h1
            class="text-3xl md:text-4xl lg:text-5xl font-bold text-text-primary-light dark:text-text-primary mb-4"
          >
            Registro de Usuario
          </h1>
          <p
            class="text-lg md:text-xl text-text-secondary-light dark:text-text-secondary leading-relaxed"
          >
            Completa tus datos para crear tu usuario
          </p>
        </div>

        <div class="max-w-md mx-auto">
          <div
            class="rounded-2xl border-2 border-border-light-mode dark:border-border-light shadow-2xl bg-bg-primary-light dark:bg-bg-primary/90 backdrop-blur-sm p-6 md:p-8 lg:p-10"
          >
            <div id="usuario-form-wrapper" class="space-y-6">
              <form id="usuario-form" class="space-y-6">
                <div>
                  <label
                    for="nombre"
                    class="block text-sm font-bold text-text-primary-light dark:text-text-primary mb-2.5"
                  >
                    Nombre
                  </label>
                  <input
                    type="text"
                    id="nombre"
                    name="nombre"
                    placeholder="Juan Pérez"
                    required
                    class="w-full px-4 py-3.5 rounded-xl bg-bg-secondary-light dark:bg-bg-secondary border-2 border-border-light-mode dark:border-border-light text-text-primary-light dark:text-text-primary placeholder:text-text-secondary-light dark:placeholder:text-text-secondary/60 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all shadow-sm hover:shadow-md"
                  />
                </div>

                <div>
                  <label
                    for="correo"
                    class="block text-sm font-bold text-text-primary-light dark:text-text-primary mb-2.5"
                  >
                    Correo
                  </label>
                  <input
                    type="email"
                    id="correo"
                    name="correo"
                    placeholder="tu@empresa.com"
                    required
                    class="w-full px-4 py-3.5 rounded-xl bg-bg-secondary-light dark:bg-bg-secondary border-2 border-border-light-mode dark:border-border-light text-text-primary-light dark:text-text-primary placeholder:text-text-secondary-light dark:placeholder:text-text-secondary/60 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all shadow-sm hover:shadow-md"
                  />
                </div>

                <div>
                  <label
                    for="rfc"
                    class="block text-sm font-bold text-text-primary-light dark:text-text-primary mb-2.5"
                  >
                    RFC
                  </label>
                  <input
                    type="text"
                    id="rfc"
                    name="rfc"
                    placeholder="XAXX010101000"
                    minlength="12"
                    maxlength="13"
                    required
                    class="w-full px-4 py-3.5 rounded-xl bg-bg-secondary-light dark:bg-bg-secondary border-2 border-border-light-mode dark:border-border-light text-text-primary-light dark:text-text-primary placeholder:text-text-secondary-light dark:placeholder:text-text-secondary/60 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all shadow-sm hover:shadow-md uppercase"
                  />
                </div>

                <div>
                  <label
                    for="password"
                    class="block text-sm font-bold text-text-primary-light dark:text-text-primary mb-2.5"
                  >
                    Contraseña
                  </label>
                  <input
                    type="password"
                    id="password"
                    name="password"
                    placeholder="••••••••"
                    required
                    class="w-full px-4 py-3.5 rounded-xl bg-bg-secondary-light dark:bg-bg-secondary border-2 border-border-light-mode dark:border-border-light text-text-primary-light dark:text-text-primary placeholder:text-text-secondary-light dark:placeholder:text-text-secondary/60 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all shadow-sm hover:shadow-md"
                  />
                </div>

                <button
                  type="submit"
                  class="w-full py-3.5 font-semibold text-base px-6 bg-gradient-to-r from-cyan-500 to-blue-500 text-white rounded-lg hover:from-cyan-600 hover:to-blue-600 transition-all duration-200 shadow-lg hover:shadow-xl cursor-pointer"
                >
                  Crear usuario
                </button>
              </form>
              <div
                id="usuario-error"
                class="hidden rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700 dark:border-red-900/60 dark:bg-red-900/20 dark:text-red-300"
              ></div>
            </div>
            <div id="usuario-feedback" class="hidden text-center space-y-5">
              <p
                id="usuario-feedback-message"
                class="text-base md:text-lg text-text-secondary-light dark:text-text-secondary leading-relaxed"
              ></p>
              <p
                id="usuario-feedback-countdown"
                class="hidden text-sm text-text-secondary-light dark:text-text-secondary"
              ></p>
              <a
                id="usuario-feedback-cta"
                href="#planes"
                class="hidden w-full inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold text-base bg-gradient-to-r from-cyan-500 to-blue-500 text-white hover:from-cyan-600 hover:to-blue-600 transition-all shadow-lg hover:shadow-xl"
              >
                Ver planes
              </a>
            </div>
          </div>
        </div>
      </div>
    </main>
    <Footer />
    <WhatsAppFloat />
    <script>
      const form = document.getElementById("usuario-form");
      const formWrapper = document.getElementById("usuario-form-wrapper");
      const feedback = document.getElementById("usuario-feedback");
      const feedbackMessage = document.getElementById(
        "usuario-feedback-message",
      );
      const feedbackCountdown = document.getElementById(
        "usuario-feedback-countdown",
      );
      const feedbackCta = document.getElementById("usuario-feedback-cta");
      const errorBox = document.getElementById("usuario-error");

      if (form) {
        form.addEventListener("submit", async (event) => {
          event.preventDefault();

          if (errorBox) {
            errorBox.textContent = "";
            errorBox.classList.add("hidden");
          }
          if (feedbackCountdown) {
            feedbackCountdown.textContent = "";
            feedbackCountdown.classList.add("hidden");
          }

          const formData = new FormData(form as HTMLFormElement);
          const correo = formData.get("correo") as string;
          const payload = {
            nombre: formData.get("nombre"),
            correo,
            rfc: formData.get("rfc"),
            password: formData.get("password"),
            origin: "solucion_factura",
          };

          try {
            const response = await fetch(
              "https://flow.wabotify.com/webhook/6ff754fd-72bb-4f96-a8da-16e90d2df4ae",
              {
                method: "POST",
                headers: {
                  "Content-Type": "application/json",
                },
                body: JSON.stringify(payload),
              },
            );
            const result = await response.json();

            if (result?.success === true && result?.code === 1) {
              if (formWrapper) formWrapper.classList.add("hidden");
              if (feedback) feedback.classList.remove("hidden");
              if (feedbackMessage) {
                feedbackMessage.textContent = `Tu usuario se está creando con tu correo ${correo} y la contraseña que introduciste.`;
              }
              if (feedbackCta) feedbackCta.classList.add("hidden");
              if (feedbackCountdown) {
                let remaining = 10;
                feedbackCountdown.textContent = `Serás redirigido en ${remaining} segundos.`;
                feedbackCountdown.classList.remove("hidden");
                const intervalId = window.setInterval(() => {
                  remaining -= 1;
                  if (remaining <= 0) {
                    window.clearInterval(intervalId);
                  } else {
                    feedbackCountdown.textContent = `Serás redirigido en ${remaining} segundos.`;
                  }
                }, 1000);
              }
              window.setTimeout(() => {
                window.location.href = "https://app.wabotify.ai/#/login";
              }, 10000);
              return;
            }

            if (result?.success === false && result?.code === 1) {
              if (formWrapper) formWrapper.classList.add("hidden");
              if (feedback) feedback.classList.remove("hidden");
              if (feedbackMessage) {
                feedbackMessage.textContent =
                  "No se puede crear tu usuario hasta que adquieras un plan Premium o Premium Plus.";
              }
              if (feedbackCta) feedbackCta.classList.remove("hidden");
              return;
            }

            if (result?.success === false && result?.code === 2) {
              if (errorBox) {
                errorBox.textContent =
                  "Correo o RFC incorrectos, intenta de nuevo.";
                errorBox.classList.remove("hidden");
              }
              return;
            }

            if (errorBox) {
              errorBox.textContent =
                "Ocurrió un error al procesar la solicitud. Intenta de nuevo.";
              errorBox.classList.remove("hidden");
            }
          } catch (error) {
            if (errorBox) {
              errorBox.textContent =
                "No se pudo conectar con el servidor. Intenta de nuevo.";
              errorBox.classList.remove("hidden");
            }
          }
        });
      }
    </script>
  </body>
</html>
